SHIP_SIM_ENV=development
SHIP_SIM_ADDR=:8080
SHIP_SIM_DATABASE_URL=postgres://shipsim:shipsim-local-dev-only@db:5432/shipsim?sslmode=disable
SHIP_SIM_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:5173,http://localhost:5173
SHIP_SIM_AUTH_MODE=off
SHIP_SIM_AUTH_TOKEN=
SHIP_SIM_AUTH_USER_HEADER=X-Forwarded-User
SHIP_SIM_STATIC_DIR=/app/web
SHIP_SIM_SCENARIO_DIR=/app/scenarios
SHIP_SIM_REQUEST_BODY_LIMIT=1048576
SHIP_SIM_RETENTION_DAYS=0
SHIP_SIM_MAX_TRACK_POINTS_PER_RUN=0
SHIP_SIM_HTTP_READ_TIMEOUT=10s
SHIP_SIM_HTTP_READ_HEADER_TIMEOUT=5s
SHIP_SIM_HTTP_WRITE_TIMEOUT=30s
SHIP_SIM_HTTP_IDLE_TIMEOUT=60s
SHIP_SIM_SHUTDOWN_TIMEOUT=15s

POSTGRES_DB=shipsim
POSTGRES_USER=shipsim
POSTGRES_PASSWORD=shipsim-local-dev-only
