SHIP_SIM_ENV=production
SHIP_SIM_ADDR=:8080
SHIP_SIM_DATABASE_URL=postgres://shipsim:replace-with-strong-random-password@db:5432/shipsim?sslmode=disable
SHIP_SIM_ALLOWED_ORIGINS=https://training.example.com
SHIP_SIM_AUTH_MODE=proxy
SHIP_SIM_AUTH_TOKEN=
SHIP_SIM_AUTH_USER_HEADER=X-Forwarded-User
SHIP_SIM_STATIC_DIR=/app/web
SHIP_SIM_SCENARIO_DIR=/app/scenarios
SHIP_SIM_REQUEST_BODY_LIMIT=1048576
SHIP_SIM_RETENTION_DAYS=30
SHIP_SIM_RETENTION_INTERVAL=6h
SHIP_SIM_MAX_TRACK_POINTS_PER_RUN=250000
SHIP_SIM_MAX_EVENTS_PER_RUN=50000
SHIP_SIM_MAX_SNAPSHOTS_PER_RUN=250000
SHIP_SIM_HTTP_READ_TIMEOUT=10s
SHIP_SIM_HTTP_READ_HEADER_TIMEOUT=5s
SHIP_SIM_HTTP_WRITE_TIMEOUT=30s
SHIP_SIM_HTTP_IDLE_TIMEOUT=60s
SHIP_SIM_SHUTDOWN_TIMEOUT=20s
SHIP_SIM_SNAPSHOT_WRITE_TIMEOUT=5s

POSTGRES_DB=shipsim
POSTGRES_USER=shipsim
POSTGRES_PASSWORD=replace-with-strong-random-password
